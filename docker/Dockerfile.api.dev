# =============================================================================
# Dockerfile.api.dev - Desarrollo con cargo-watch (hot-reload)
# =============================================================================
# El codigo fuente se monta como volumen en docker-compose.dev.yml.
# cargo-watch recompila automaticamente al detectar cambios.
# =============================================================================

FROM rust:1.88-bookworm

# Instalar curl para healthcheck (no siempre presente en bookworm)
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# Instalar cargo-watch para hot-reload
# NOTA: cargo-watch fue archivado en Ene 2025 pero sigue funcional.
# Alternativa futura: bacon (cargo install --locked bacon)
RUN cargo install cargo-watch

WORKDIR /app

# Copiar manifiestos para cachear dependencias
COPY src/api/Cargo.toml src/api/Cargo.lock ./
COPY src/api/migrations ./migrations

# Compilar dependencias con un main.rs dummy (cache layer).
# Esto permite que las dependencias se cacheen en una capa Docker separada.
# El directorio migrations/ ya esta copiado para satisfacer sqlx::migrate!()
# en caso de que se invoque, aunque el dummy main.rs no lo hace.
RUN mkdir src && \
    echo 'fn main() { println!("placeholder"); }' > src/main.rs && \
    cargo build && \
    rm -rf src

EXPOSE 3000

# Entrypoint: invalidar la compilacion del dummy para forzar recompilacion
# con el codigo fuente real montado via bind mount. Eliminar binario y los
# fingerprints incrementales, luego arrancar cargo-watch.
CMD rm -rf target/debug/.fingerprint/lab-17025-api-* \
           target/debug/deps/lab_17025_api-* \
           target/debug/lab-17025-api* \
           target/debug/lab_17025_api* && \
    cargo watch -x run -w src -w migrations --why
