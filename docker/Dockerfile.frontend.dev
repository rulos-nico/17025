# =============================================================================
# Dockerfile.frontend.dev - Vite dev server con HMR
# =============================================================================
# El codigo fuente se monta como volumen en docker-compose.dev.yml.
# Vite dev server con --host 0.0.0.0 para acceso desde fuera del container.
# =============================================================================

FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

# El codigo fuente se monta como volumen bind
EXPOSE 5173

# --host 0.0.0.0 es necesario para que el server sea accesible desde fuera del container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
